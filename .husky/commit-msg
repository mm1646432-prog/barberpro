#!/usr/bin/env sh
# Enforces Conventional Commits format: https://www.conventionalcommits.org
#
# Valid examples:
#   feat: add booking wizard
#   fix: correct slot availability calculation
#   chore: update dependencies
#   docs: add deployment guide

commit_msg=$(cat "$1")
pattern="^(feat|fix|chore|docs|refactor|style|test|perf|ci|build|revert)(\(.+\))?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  ✗ Invalid commit message format."
  echo ""
  echo "  Use Conventional Commits: <type>(<scope>): <description>"
  echo ""
  echo "  Types: feat | fix | chore | docs | refactor | style | test | perf | ci | build | revert"
  echo ""
  echo "  Examples:"
  echo "    feat: add booking wizard"
  echo "    fix(auth): redirect after login"
  echo "    chore: update dependencies"
  echo ""
  exit 1
fi
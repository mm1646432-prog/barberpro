# EditorConfig — https://editorconfig.org
# Ensures consistent formatting regardless of editor or OS.

root = true

# ── Defaults: all files ───────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ── TypeScript / JavaScript ───────────────────────────────────────────────────
[*.{ts,tsx,js,mjs,cjs,jsx}]
indent_size = 2
max_line_length = 80

# ── JSON ─────────────────────────────────────────────────────────────────────
[*.{json,jsonc}]
indent_size = 2

# ── CSS ──────────────────────────────────────────────────────────────────────
[*.css]
indent_size = 2

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

# ── YAML ─────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ── SQL ──────────────────────────────────────────────────────────────────────
[*.sql]
indent_size = 2

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_style = tab

# ── Makefiles ─────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab